generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  UNKNOWN
  MALE
  FEMALE
}

enum DiscountType {
  NONE
  FIXED
  PERCENT
}

enum StaffRole {
  OWNER
  ADMIN
  MASTER
  DEVELOPER
  SMM
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ARRIVED
  NO_SHOW
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum ActorType {
  CLIENT
  STAFF
  SYSTEM
}

enum PushEnvironment {
  SANDBOX
  PRODUCTION
}

enum ClientContentStatus {
  DRAFT
  PUBLISHED
}

enum ClientPlatform {
  ALL
  IOS
  ANDROID
  WEB
}

model ClientCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  clients Client[]
}

model Client {
  id                     String       @id @default(uuid())
  externalId             String?
  phone10                String       @unique
  phoneE164              String
  name                   String?
  avatarPath             String?
  gender                 Gender       @default(UNKNOWN)
  birthday               DateTime?
  comment                String?
  categoryId             String?
  discountType           DiscountType @default(NONE)
  discountValue          Decimal?     @db.Decimal(12, 2)
  temporaryDiscountType  DiscountType @default(NONE)
  temporaryDiscountValue Decimal?     @db.Decimal(12, 2)
  temporaryDiscountFrom  DateTime?
  temporaryDiscountTo    DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  category         ClientCategory?       @relation(fields: [categoryId], references: [id])
  account          ClientAccount?
  appointments     Appointment[]
  promoRedemptions PromoCodeRedemption[]

  @@index([categoryId])
}

model ClientAccount {
  id           String    @id @default(uuid())
  clientId     String    @unique
  email        String?   @unique
  passwordHash String
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  passwordResetUsedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([passwordResetTokenHash])
  @@index([passwordResetExpiresAt])
  @@index([passwordResetUsedAt])
}

model Position {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  staff Staff[]
}

model Staff {
  id         String    @id @default(uuid())
  email      String?   @unique
  name       String
  role       StaffRole
  phone10    String    @unique
  phoneE164  String
  positionId String?
  pinHash    String?
  hiredAt    DateTime?
  firedAt    DateTime?
  deletedAt  DateTime?
  isActive   Boolean   @default(true)
  receivesAllAppointmentNotifications Boolean @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  position                    Position?                 @relation(fields: [positionId], references: [id])
  permissions                 StaffPermission[]         @relation("staff_permissions")
  grantedPermissions          StaffPermission[]         @relation("granted_by")
  staffServices               StaffService[]
  workingHours                WorkingHours[]
  dailySchedules              StaffDailySchedule[]
  timeOff                     TimeOff[]
  blocks                      Block[]
  appointments                Appointment[]
  paymentsCreated             Payment[]
  tokens                      StaffToken[]
  importJobs                  ImportJob[]
  promoCodesCreated           PromoCode[]               @relation("promo_created_by")
  clientBlocksCreated         ClientContentBlock[]      @relation("client_block_created_by")
  clientBlocksUpdated         ClientContentBlock[]      @relation("client_block_updated_by")
  clientBlocksPublished       ClientContentBlock[]      @relation("client_block_published_by")
  clientReleasesPublished     ClientContentRelease[]    @relation("client_release_published_by")
  mediaAssetsUploaded         MediaAsset[]              @relation("media_uploaded_by")
  mediaUsagesCreated          MediaUsage[]              @relation("media_usage_created_by")
  auditLogs                   AuditLog[]                @relation("audit_actor_staff")
  specialistProfile           ClientSpecialistProfile?
  specialistProfilesUpdated   ClientSpecialistProfile[] @relation("specialist_profile_updated_by")
  specialistProfilesPublished ClientSpecialistProfile[] @relation("specialist_profile_published_by")
  pushDevices                 StaffPushDevice[]

  @@index([role])
  @@index([positionId])
  @@index([deletedAt])
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique
  description String

  staffPermissions StaffPermission[]
}

model StaffPermission {
  id               String    @id @default(uuid())
  staffId          String
  permissionId     String
  grantedByStaffId String
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  staff          Staff      @relation("staff_permissions", fields: [staffId], references: [id], onDelete: Cascade)
  permission     Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByStaff Staff      @relation("granted_by", fields: [grantedByStaffId], references: [id], onDelete: Restrict)

  @@unique([staffId, permissionId])
  @@index([staffId])
  @@index([permissionId])
  @@index([expiresAt])
}

model Session {
  id               String    @id @default(uuid())
  subjectType      String
  subjectId        String
  refreshTokenHash String
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([subjectType, subjectId])
  @@index([expiresAt])
}

model StaffToken {
  id        String    @id @default(uuid())
  staffId   String
  type      String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AppConfig {
  id                           String   @id @default(uuid())
  singleton                    String   @unique @default("default")
  clientCancelMinNoticeMinutes Int      @default(120)
  notificationMinNoticeMinutes Int      @default(120)
  notificationSettings         Json     @default("{}")
  privacyPolicy                String   @default("") @db.Text
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model NotificationDispatch {
  id             String   @id @default(uuid())
  dispatchKey    String   @unique
  notificationId String
  recipientEmail String
  meta           Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([notificationId, createdAt])
  @@index([recipientEmail])
}

model StaffPushDevice {
  id          String          @id @default(uuid())
  staffId      String
  token        String          @unique
  environment  PushEnvironment
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lastSeenAt   DateTime        @default(now())

  staff       Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dispatches  PushDispatch[]

  @@index([staffId])
  @@index([environment])
}

model PushDispatch {
  id                String   @id @default(uuid())
  dispatchKey       String   @unique
  notificationId    String
  staffPushDeviceId String
  createdAt         DateTime @default(now())

  device StaffPushDevice @relation(fields: [staffPushDeviceId], references: [id], onDelete: Cascade)

  @@index([notificationId, createdAt])
  @@index([staffPushDeviceId])
}

model ClientAppConfig {
  id                            String    @id @default(uuid())
  singleton                     String    @unique @default("default")
  brandNameDraft                String?
  legalNameDraft                String?
  minAppVersionIosDraft         String?
  minAppVersionAndroidDraft     String?
  maintenanceModeDraft          Boolean   @default(false)
  maintenanceMessageDraft       String?
  featureFlagsDraft             Json      @default("{}")
  contactsDraft                 Json      @default("[]")
  extraDraft                    Json      @default("{}")
  brandNamePublished            String?
  legalNamePublished            String?
  minAppVersionIosPublished     String?
  minAppVersionAndroidPublished String?
  maintenanceModePublished      Boolean   @default(false)
  maintenanceMessagePublished   String?
  featureFlagsPublished         Json      @default("{}")
  contactsPublished             Json      @default("[]")
  extraPublished                Json      @default("{}")
  publishedVersion              Int       @default(0)
  publishedReleaseId            String?
  publishedAt                   DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  publishedRelease ClientContentRelease? @relation(fields: [publishedReleaseId], references: [id], onDelete: SetNull)
}

model ClientContentRelease {
  id                 String   @id @default(uuid())
  version            Int      @unique
  etag               String   @unique
  appConfigSnapshot  Json
  blocksCount        Int
  publishedByStaffId String
  publishedAt        DateTime @default(now())

  publishedByStaff Staff                @relation("client_release_published_by", fields: [publishedByStaffId], references: [id], onDelete: Restrict)
  blocks           ClientContentBlock[] @relation("release_blocks")
  appConfigs       ClientAppConfig[]

  @@index([publishedAt])
}

model ClientContentBlock {
  id                 String              @id @default(uuid())
  blockKey           String
  blockType          String
  payload            Json
  sortOrder          Int                 @default(0)
  status             ClientContentStatus @default(DRAFT)
  platform           ClientPlatform      @default(ALL)
  minAppVersion      String?
  maxAppVersion      String?
  startAt            DateTime?
  endAt              DateTime?
  isEnabled          Boolean             @default(true)
  releaseId          String?
  createdByStaffId   String?
  updatedByStaffId   String?
  publishedByStaffId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  release          ClientContentRelease? @relation("release_blocks", fields: [releaseId], references: [id], onDelete: SetNull)
  createdByStaff   Staff?                @relation("client_block_created_by", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  updatedByStaff   Staff?                @relation("client_block_updated_by", fields: [updatedByStaffId], references: [id], onDelete: SetNull)
  publishedByStaff Staff?                @relation("client_block_published_by", fields: [publishedByStaffId], references: [id], onDelete: SetNull)

  @@index([status, sortOrder])
  @@index([blockType])
  @@index([platform, minAppVersion, maxAppVersion])
  @@index([startAt, endAt])
  @@index([releaseId])
}

model ClientSpecialistProfile {
  id                    String   @id @default(uuid())
  staffId               String   @unique
  photoAssetIdDraft     String?
  photoAssetIdPublished String?
  specialtyDraft        String?
  specialtyPublished    String?
  infoDraft             String?
  infoPublished         String?
  ctaTextDraft          String   @default("Записаться")
  ctaTextPublished      String   @default("Записаться")
  isVisibleDraft        Boolean  @default(true)
  isVisiblePublished    Boolean  @default(true)
  sortOrderDraft        Int      @default(0)
  sortOrderPublished    Int      @default(0)
  updatedByStaffId      String?
  publishedByStaffId    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  staff            Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  photoDraft       MediaAsset? @relation("specialist_photo_draft", fields: [photoAssetIdDraft], references: [id], onDelete: SetNull)
  photoPublished   MediaAsset? @relation("specialist_photo_published", fields: [photoAssetIdPublished], references: [id], onDelete: SetNull)
  updatedByStaff   Staff?      @relation("specialist_profile_updated_by", fields: [updatedByStaffId], references: [id], onDelete: SetNull)
  publishedByStaff Staff?      @relation("specialist_profile_published_by", fields: [publishedByStaffId], references: [id], onDelete: SetNull)

  @@index([isVisibleDraft, sortOrderDraft])
  @@index([isVisiblePublished, sortOrderPublished])
  @@index([updatedByStaffId])
  @@index([publishedByStaffId])
}

model MediaAsset {
  id               String   @id @default(uuid())
  entity           String
  originalFileName String
  originalMime     String
  originalSize     Int
  originalWidth    Int
  originalHeight   Int
  checksumSha256   String
  originalPath     String
  createdByStaffId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdByStaff                   Staff                     @relation("media_uploaded_by", fields: [createdByStaffId], references: [id], onDelete: Restrict)
  variants                         MediaVariant[]
  usages                           MediaUsage[]
  serviceCategoryImageUsages       ServiceCategory[]         @relation("service_category_image")
  specialistPhotoDraftProfiles     ClientSpecialistProfile[] @relation("specialist_photo_draft")
  specialistPhotoPublishedProfiles ClientSpecialistProfile[] @relation("specialist_photo_published")

  @@index([entity, createdAt])
  @@index([checksumSha256])
  @@index([createdByStaffId])
}

model MediaVariant {
  id        String   @id @default(uuid())
  assetId   String
  format    String
  width     Int
  height    Int
  path      String
  urlPath   String
  size      Int
  createdAt DateTime @default(now())

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, format, width])
  @@index([assetId])
}

model MediaUsage {
  id               String   @id @default(uuid())
  assetId          String
  usageType        String
  entityId         String
  fieldPath        String   @default("")
  note             String?
  createdByStaffId String?
  createdAt        DateTime @default(now())

  asset          MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdByStaff Staff?     @relation("media_usage_created_by", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@unique([assetId, usageType, entityId, fieldPath])
  @@index([usageType, entityId])
  @@index([assetId])
  @@index([createdByStaffId])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorStaffId String?
  action       String
  entityType   String
  entityId     String
  diff         Json?
  metadata     Json?
  createdAt    DateTime @default(now())

  actorStaff Staff? @relation("audit_actor_staff", fields: [actorStaffId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorStaffId, createdAt])
}

model PromoCode {
  id                  String       @id @default(uuid())
  code                String       @unique
  name                String?
  description         String?
  discountType        DiscountType
  discountValue       Decimal      @db.Decimal(12, 2)
  isActive            Boolean      @default(true)
  startsAt            DateTime?
  endsAt              DateTime?
  maxUsages           Int?
  perClientUsageLimit Int?
  usedCount           Int          @default(0)
  createdByStaffId    String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  createdByStaff Staff?                @relation("promo_created_by", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  redemptions    PromoCodeRedemption[]

  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model PromoCodeRedemption {
  id                     String       @id @default(uuid())
  promoCodeId            String
  clientId               String
  appointmentId          String       @unique
  discountTypeSnapshot   DiscountType
  discountValueSnapshot  Decimal?     @db.Decimal(12, 2)
  discountAmountSnapshot Decimal      @db.Decimal(12, 2)
  createdAt              DateTime     @default(now())

  promoCode   PromoCode   @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([clientId])
}

model ServiceCategory {
  id           String      @id @default(uuid())
  name         String      @unique
  imageAssetId String?

  imageAsset MediaAsset? @relation("service_category_image", fields: [imageAssetId], references: [id], onDelete: SetNull)
  services   Service[]

  @@index([imageAssetId])
}

model Service {
  id          String   @id @default(uuid())
  externalId  String?
  categoryId  String
  name        String
  nameReceipt String?
  nameOnline  String?
  description String?
  durationSec Int
  priceMin    Decimal  @db.Decimal(12, 2)
  priceMax    Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)

  category            ServiceCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  staffServices       StaffService[]
  appointmentServices AppointmentService[]

  @@index([externalId])
  @@index([categoryId])
}

model StaffService {
  id        String @id @default(uuid())
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model WorkingHours {
  id        String @id @default(uuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  bookingStartTime String?
  bookingEndTime   String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([dayOfWeek])
}

model TimeOff {
  id      String   @id @default(uuid())
  staffId String
  startAt DateTime
  endAt   DateTime
  reason  String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([startAt])
}

model Block {
  id      String   @id @default(uuid())
  staffId String
  startAt DateTime
  endAt   DateTime
  reason  String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([startAt])
}

model StaffDailySchedule {
  id        String   @id @default(uuid())
  staffId   String
  date      DateTime
  intervals Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([date])
}

model Appointment {
  id                     String            @id @default(uuid())
  externalId             String            @unique
  clientId               String
  staffId                String
  startAt                DateTime
  endAt                  DateTime
  status                 AppointmentStatus
  baseTotalPrice         Decimal           @db.Decimal(12, 2)
  discountTypeSnapshot   DiscountType
  discountValueSnapshot  Decimal?          @db.Decimal(12, 2)
  discountAmountSnapshot Decimal           @db.Decimal(12, 2)
  finalTotalPrice        Decimal           @db.Decimal(12, 2)
  paymentStatus          PaymentStatus
  paymentMethod          PaymentMethod
  paidAmount             Decimal           @db.Decimal(12, 2)
  createdByType          ActorType
  createdById            String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  client              Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  staff               Staff                @relation(fields: [staffId], references: [id], onDelete: Restrict)
  appointmentServices AppointmentService[]
  payments            Payment[]
  promoRedemption     PromoCodeRedemption?

  @@index([staffId, startAt])
  @@index([clientId, startAt])
  @@index([startAt])
}

model AppointmentService {
  id                        String  @id @default(uuid())
  appointmentId             String
  serviceId                 String?
  serviceNameSnapshot       String
  durationSnapshotSec       Int
  priceSnapshot             Decimal @db.Decimal(12, 2)
  priceWithDiscountSnapshot Decimal @db.Decimal(12, 2)
  sortOrder                 Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
}

model Payment {
  id               String        @id @default(uuid())
  appointmentId    String
  amount           Decimal       @db.Decimal(12, 2)
  method           PaymentMethod
  createdByStaffId String?
  createdAt        DateTime      @default(now())

  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdByStaff Staff?      @relation(fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([createdAt])
}

model ImportJob {
  id                String    @id @default(uuid())
  type              String
  uploadedByStaffId String
  createdCount      Int       @default(0)
  updatedCount      Int       @default(0)
  skippedCount      Int       @default(0)
  errorCount        Int       @default(0)
  status            String
  createdAt         DateTime  @default(now())
  finishedAt        DateTime?

  uploadedByStaff Staff               @relation(fields: [uploadedByStaffId], references: [id], onDelete: Restrict)
  errors          ImportJobErrorRow[]

  @@index([type])
  @@index([createdAt])
}

model ImportJobErrorRow {
  id           String @id @default(uuid())
  importJobId  String
  rowNumber    Int
  rawData      Json
  errorMessage String

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
}
