generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  UNKNOWN
  MALE
  FEMALE
}

enum DiscountType {
  NONE
  FIXED
  PERCENT
}

enum StaffRole {
  OWNER
  ADMIN
  MASTER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ARRIVED
  NO_SHOW
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum ActorType {
  CLIENT
  STAFF
  SYSTEM
}

model ClientCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  clients Client[]
}

model Client {
  id            String       @id @default(uuid())
  externalId    String?
  phone10       String       @unique
  phoneE164     String
  name          String?
  gender        Gender       @default(UNKNOWN)
  birthday      DateTime?
  comment       String?
  categoryId    String?
  discountType            DiscountType @default(NONE)
  discountValue           Decimal?     @db.Decimal(12, 2)
  temporaryDiscountType   DiscountType @default(NONE)
  temporaryDiscountValue  Decimal?     @db.Decimal(12, 2)
  temporaryDiscountFrom   DateTime?
  temporaryDiscountTo     DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  category        ClientCategory?       @relation(fields: [categoryId], references: [id])
  account         ClientAccount?
  appointments    Appointment[]
  promoRedemptions PromoCodeRedemption[]

  @@index([categoryId])
}

model ClientAccount {
  id           String    @id @default(uuid())
  clientId     String    @unique
  email        String?   @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Position {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  staff Staff[]
}

model Staff {
  id         String    @id @default(uuid())
  email      String?   @unique
  name       String
  role       StaffRole
  phone10    String    @unique
  phoneE164  String
  positionId String?
  pinHash    String?
  hiredAt    DateTime?
  firedAt    DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  position           Position?         @relation(fields: [positionId], references: [id])
  permissions        StaffPermission[] @relation("staff_permissions")
  grantedPermissions StaffPermission[] @relation("granted_by")
  staffServices      StaffService[]
  workingHours       WorkingHours[]
  timeOff            TimeOff[]
  blocks             Block[]
  appointments       Appointment[]
  paymentsCreated    Payment[]
  tokens             StaffToken[]
  importJobs         ImportJob[]
  promoCodesCreated  PromoCode[]        @relation("promo_created_by")

  @@index([role])
  @@index([positionId])
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique
  description String

  staffPermissions StaffPermission[]
}

model StaffPermission {
  id               String    @id @default(uuid())
  staffId          String
  permissionId     String
  grantedByStaffId String
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  staff          Staff      @relation("staff_permissions", fields: [staffId], references: [id], onDelete: Cascade)
  permission     Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByStaff Staff      @relation("granted_by", fields: [grantedByStaffId], references: [id], onDelete: Restrict)

  @@unique([staffId, permissionId])
  @@index([staffId])
  @@index([permissionId])
  @@index([expiresAt])
}

model Session {
  id               String    @id @default(uuid())
  subjectType      String
  subjectId        String
  refreshTokenHash String
  userAgent        String?
  ip               String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([subjectType, subjectId])
  @@index([expiresAt])
}

model StaffToken {
  id        String    @id @default(uuid())
  staffId   String
  type      String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AppConfig {
  id                           String   @id @default(uuid())
  singleton                    String   @unique @default("default")
  clientCancelMinNoticeMinutes Int      @default(120)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model PromoCode {
  id                  String       @id @default(uuid())
  code                String       @unique
  name                String?
  description         String?
  discountType        DiscountType
  discountValue       Decimal      @db.Decimal(12, 2)
  isActive            Boolean      @default(true)
  startsAt            DateTime?
  endsAt              DateTime?
  maxUsages           Int?
  perClientUsageLimit Int?
  usedCount           Int          @default(0)
  createdByStaffId    String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  createdByStaff Staff?                @relation("promo_created_by", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  redemptions    PromoCodeRedemption[]

  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}

model PromoCodeRedemption {
  id                     String       @id @default(uuid())
  promoCodeId            String
  clientId               String
  appointmentId          String       @unique
  discountTypeSnapshot   DiscountType
  discountValueSnapshot  Decimal?     @db.Decimal(12, 2)
  discountAmountSnapshot Decimal      @db.Decimal(12, 2)
  createdAt              DateTime     @default(now())

  promoCode   PromoCode   @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([clientId])
}

model ServiceCategory {
  id   String @id @default(uuid())
  name String @unique

  services Service[]
}

model Service {
  id          String   @id @default(uuid())
  externalId  String?
  categoryId  String
  name        String
  nameReceipt String?
  nameOnline  String?
  description String?
  durationSec Int
  priceMin    Decimal  @db.Decimal(12, 2)
  priceMax    Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)

  category            ServiceCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  staffServices       StaffService[]
  appointmentServices AppointmentService[]

  @@index([externalId])
  @@index([categoryId])
}

model StaffService {
  id        String @id @default(uuid())
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model WorkingHours {
  id        String @id @default(uuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([dayOfWeek])
}

model TimeOff {
  id      String   @id @default(uuid())
  staffId String
  startAt DateTime
  endAt   DateTime
  reason  String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([startAt])
}

model Block {
  id      String   @id @default(uuid())
  staffId String
  startAt DateTime
  endAt   DateTime
  reason  String?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([startAt])
}

model Appointment {
  id                     String            @id @default(uuid())
  externalId             String            @unique
  clientId               String
  staffId                String
  startAt                DateTime
  endAt                  DateTime
  status                 AppointmentStatus
  baseTotalPrice         Decimal           @db.Decimal(12, 2)
  discountTypeSnapshot   DiscountType
  discountValueSnapshot  Decimal?          @db.Decimal(12, 2)
  discountAmountSnapshot Decimal           @db.Decimal(12, 2)
  finalTotalPrice        Decimal           @db.Decimal(12, 2)
  paymentStatus          PaymentStatus
  paymentMethod          PaymentMethod
  paidAmount             Decimal           @db.Decimal(12, 2)
  createdByType          ActorType
  createdById            String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  client              Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  staff               Staff                @relation(fields: [staffId], references: [id], onDelete: Restrict)
  appointmentServices AppointmentService[]
  payments            Payment[]
  promoRedemption     PromoCodeRedemption?

  @@index([staffId, startAt])
  @@index([clientId, startAt])
  @@index([startAt])
}

model AppointmentService {
  id                        String  @id @default(uuid())
  appointmentId             String
  serviceId                 String?
  serviceNameSnapshot       String
  durationSnapshotSec       Int
  priceSnapshot             Decimal @db.Decimal(12, 2)
  priceWithDiscountSnapshot Decimal @db.Decimal(12, 2)
  sortOrder                 Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
}

model Payment {
  id               String        @id @default(uuid())
  appointmentId    String
  amount           Decimal       @db.Decimal(12, 2)
  method           PaymentMethod
  createdByStaffId String?
  createdAt        DateTime      @default(now())

  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  createdByStaff Staff?      @relation(fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([createdAt])
}

model ImportJob {
  id                String    @id @default(uuid())
  type              String
  uploadedByStaffId String
  createdCount      Int       @default(0)
  updatedCount      Int       @default(0)
  skippedCount      Int       @default(0)
  errorCount        Int       @default(0)
  status            String
  createdAt         DateTime  @default(now())
  finishedAt        DateTime?

  uploadedByStaff Staff               @relation(fields: [uploadedByStaffId], references: [id], onDelete: Restrict)
  errors          ImportJobErrorRow[]

  @@index([type])
  @@index([createdAt])
}

model ImportJobErrorRow {
  id           String @id @default(uuid())
  importJobId  String
  rowNumber    Int
  rawData      Json
  errorMessage String

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
}
